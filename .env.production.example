# Production Environment Configuration
# Copy this file to .env.production and fill in with production values

# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key

# Application Configuration
APP_URL=https://your-domain.com
NODE_ENV=production

# Security: Keep debug mode disabled in production for better performance
# VITE_DEBUG should be removed or set to 'false'

# Server-only credentials (never expose to frontend)
# These should only be used in Edge Functions or backend
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# RESEND_API_KEY=your-resend-api-key
